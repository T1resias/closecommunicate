.location-bar {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  background: #fff;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
  font-size: 26rpx;
}

.location-dot {
  width: 16rpx;
  height: 16rpx;
  border-radius: 50%;
  background: var(--primary);
  margin-right: 12rpx;
  flex-shrink: 0;
}

.retry-btn {
  margin-left: auto;
  font-size: 24rpx;
  padding: 8rpx 20rpx;
  background: var(--primary);
  color: #fff;
  border-radius: 8rpx;
  line-height: 1.4;
}

.error-card {
  text-align: center;
  color: var(--danger);
}

.loading {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 120rpx 0;
  color: var(--text-light);
}

.loading-spinner {
  width: 60rpx;
  height: 60rpx;
  border: 4rpx solid #eee;
  border-top-color: var(--primary);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
  margin-bottom: 20rpx;
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

.empty {
  text-align: center;
  padding: 80rpx;
  color: var(--text-light);
}

.sub-text {
  display: block;
  font-size: 24rpx;
  margin-top: 10rpx;
}

.child-forums {
  margin-left: 32rpx;
}

.tip {
  text-align: center;
  color: var(--text-light);
  font-size: 24rpx;
  padding: 40rpx 0;
}
