.forum-header {
  margin-bottom: 20rpx;
}

.forum-name {
  font-size: 36rpx;
  font-weight: 600;
  margin-bottom: 12rpx;
}

.forum-type {
  display: inline-block;
  background: #e8f8ef;
  color: var(--primary);
  font-size: 22rpx;
  padding: 4rpx 16rpx;
  border-radius: 20rpx;
  margin-bottom: 12rpx;
}

.forum-desc {
  font-size: 26rpx;
  color: #666;
  line-height: 1.6;
  margin-bottom: 12rpx;
}

.forum-address {
  font-size: 24rpx;
  color: var(--text-light);
  display: flex;
  align-items: center;
  margin-bottom: 8rpx;
}

.addr-dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: var(--primary);
  margin-right: 8rpx;
  flex-shrink: 0;
}

.forum-meta {
  font-size: 24rpx;
  color: var(--text-light);
}

.empty-msg {
  text-align: center;
  padding: 80rpx 0;
  color: var(--text-light);
}

.loading-tip {
  text-align: center;
  padding: 30rpx;
  color: var(--text-light);
  font-size: 24rpx;
}

.input-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  display: flex;
  align-items: center;
  padding: 16rpx 20rpx;
  background: #fff;
  border-top: 1rpx solid var(--border);
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
}

.msg-input {
  flex: 1;
  height: 72rpx;
  background: #f5f5f5;
  border-radius: 36rpx;
  padding: 0 28rpx;
  font-size: 28rpx;
}

.send-btn {
  margin-left: 16rpx;
  padding: 12rpx 32rpx;
  background: var(--primary);
  color: #fff;
  font-size: 28rpx;
  border-radius: 36rpx;
  line-height: 1.2;
}

.send-btn[disabled] {
  background: #c0c0c0;
}

/* 给消息列表底部留出输入栏空间 */
.msg-list {
  padding-bottom: 140rpx;
}
